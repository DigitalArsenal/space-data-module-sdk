{
  "pluginId": "com.digitalarsenal.examples.single-file-vector",
  "name": "Single File Vector",
  "version": "0.1.0",
  "pluginFamily": "analysis",
  "capabilities": ["clock"],
  "externalInterfaces": [],
  "methods": [
    {
      "methodId": "propagate",
      "displayName": "Propagate",
      "inputPorts": [
        {
          "portId": "request",
          "acceptedTypeSets": [
            {
              "setId": "omm",
              "allowedTypes": [
                {
                  "schemaName": "OMM.fbs",
                  "fileIdentifier": "$OMM"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "outputPorts": [
        {
          "portId": "state",
          "acceptedTypeSets": [
            {
              "setId": "cat",
              "allowedTypes": [
                {
                  "schemaName": "CAT.fbs",
                  "fileIdentifier": "$CAT"
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "maxBatch": 1,
      "drainPolicy": "single-shot"
    }
  ]
}
