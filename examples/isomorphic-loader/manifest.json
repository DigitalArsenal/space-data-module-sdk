{
  "pluginId": "com.digitalarsenal.examples.isomorphic-echo",
  "name": "Isomorphic Echo",
  "version": "0.1.0",
  "pluginFamily": "analysis",
  "runtimeTargets": ["browser", "wasmedge"],
  "invokeSurfaces": ["command"],
  "capabilities": ["logging", "filesystem"],
  "externalInterfaces": [],
  "methods": [
    {
      "methodId": "echo",
      "displayName": "Echo",
      "inputPorts": [
        {
          "portId": "request",
          "acceptedTypeSets": [
            {
              "setId": "request-cat",
              "allowedTypes": [
                {
                  "schemaName": "CAT.fbs",
                  "fileIdentifier": "$CAT",
                  "rootTypeName": "CAT",
                  "wireFormat": "flatbuffer"
                },
                {
                  "schemaName": "CAT.fbs",
                  "fileIdentifier": "$CAT",
                  "rootTypeName": "CAT",
                  "wireFormat": "aligned-binary",
                  "byteLength": 64,
                  "requiredAlignment": 8
                }
              ]
            }
          ],
          "minStreams": 1,
          "maxStreams": 1,
          "required": true
        }
      ],
      "outputPorts": [
        {
          "portId": "response",
          "acceptedTypeSets": [
            {
              "setId": "response-cat",
              "allowedTypes": [
                {
                  "schemaName": "CAT.fbs",
                  "fileIdentifier": "$CAT",
                  "rootTypeName": "CAT",
                  "wireFormat": "flatbuffer"
                },
                {
                  "schemaName": "CAT.fbs",
                  "fileIdentifier": "$CAT",
                  "rootTypeName": "CAT",
                  "wireFormat": "aligned-binary",
                  "byteLength": 64,
                  "requiredAlignment": 8
                }
              ]
            }
          ],
          "minStreams": 0,
          "maxStreams": 1,
          "required": false
        }
      ],
      "maxBatch": 1,
      "drainPolicy": "single-shot"
    }
  ]
}
